# ═══════════════════════════════════════════
#  FB Downloader Pro — Server Config
#  Render/Railway pe yeh Environment Variables set karo
# ═══════════════════════════════════════════

# Tumhara same secret jo license_engine.py mein hai
MASTER_SECRET=FBDLPRO_CHANGE_THIS_TO_SOMETHING_UNIQUE_2025

# Admin dashboard password — strong rakhna
ADMIN_PASSWORD=YourStrongAdminPassword123!

# Current app version
CURRENT_VERSION=3.1.0

# Minimum supported version
# Isse badlo to purane sab FORCE UPDATE honge!
# Jaise: 3.2.0 set kiya to 3.1.0 wale sab band
MIN_VERSION=3.1.0

# Port (Render apne aap set karta hai)
PORT=3000
